# ============================================================================
# Unified Inbox — Environment Variables Template
# ============================================================================
# Copy to .env (local dev) or .env.production (VPS) and fill in real values.
#
# NEVER commit real secrets to Git.
# Generate JWT_SECRET with: openssl rand -hex 64
# ============================================================================

PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
JWT_SECRET=<generate-with: openssl rand -hex 64>

# CORS — restrict in production, leave empty or * for dev
# CORS_ORIGIN=https://yourdomain.com

# WhatsApp Business API
WHATSAPP_API_URL=https://graph.facebook.com/v24.0
WHATSAPP_PHONE_NUMBER_ID=<your-phone-number-id>
WHATSAPP_ACCESS_TOKEN=<your-whatsapp-token>
WHATSAPP_VERIFY_TOKEN=<your-verify-token>

# Facebook
FACEBOOK_VERIFY_TOKEN=<your-fb-verify-token>
FACEBOOK_APP_ID=<your-app-id>
FACEBOOK_APP_SECRET=<your-app-secret>
FACEBOOK_PAGE_ID=<your-page-id>
FACEBOOK_PAGE_ACCESS_TOKEN=<your-page-token>

# Instagram
INSTAGRAM_ACCESS_TOKEN=<your-ig-token>
INSTAGRAM_ACCOUNT_ID=<your-ig-account-id>

# Email (IMAP for reading, SMTP for sending)
EMAIL_USER=<email@example.com>
EMAIL_PASSWORD=<email-password>
EMAIL_IMAP_HOST=<imap.example.com>
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=<smtp.example.com>
EMAIL_SMTP_PORT=587
EMAIL_FROM_NAME=MedTour Unified Inbox
